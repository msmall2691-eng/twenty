# Database
DATABASE_URL="file:./dev.db"

# App
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3100"

# Email (Nodemailer / SendGrid)
EMAIL_FROM="noreply@mainecleaning.company"
EMAIL_HOST="smtp.sendgrid.net"
EMAIL_PORT="587"
EMAIL_USER="apikey"
EMAIL_PASS="your-sendgrid-api-key"

# SMS (Twilio)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_FROM_PHONE="+1xxxxxxxxxx"

# Google Calendar
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3100/api/integrations/google-calendar/callback"
GOOGLE_CALENDAR_ID="primary"

# Square
SQUARE_ACCESS_TOKEN="your-square-access-token"
SQUARE_LOCATION_ID="your-square-location-id"
SQUARE_ENVIRONMENT="sandbox"  # or "production"

# ConnectTeam
CONNECT_TEAM_API_KEY="your-connect-team-api-key"
CONNECT_TEAM_API_URL="https://api.connecteam.com/api/v1"

# Intake Webhook Secret (set on WW.MaineCleaning.Company)
INTAKE_WEBHOOK_SECRET="your-intake-webhook-secret"
